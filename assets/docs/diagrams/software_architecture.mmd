flowchart TB
    UI["用户交互层\n语音输入 / 网页清单 / 状态反馈"] --> DEC["任务决策层\n清单解析 / 推荐决策 / 任务规划 / 异常决策"]
    ENV["环境信息层\n天气模拟 / 交通模拟 / 日程模拟"] --> DEC
    DATA["数据管理层\n物品库 / 习惯数据 / 任务日志"] --> DEC
    DEC --> PER["感知定位层\n视觉识别 / 标签识别 / 习惯位置预测 / 坐标转换"]
    PER --> EXE["机器人执行层\n导航 / 搜索 / 抓取 / 放置确认"]
    EXE --> UI
    EXE --> DATA
